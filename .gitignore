# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build outputs
dist
dist-ssr
*.tsbuildinfo

# Environment files
*.local
.env
.env.*
!.env.example
server/.env

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary files
Temp/
temp/

# Native mobile builds (Capacitor)
packages/mobile/ios/App/Pods
packages/mobile/ios/DerivedData
packages/mobile/ios/*.xcworkspace
packages/mobile/android/app/build
packages/mobile/android/.gradle
packages/mobile/android/local.properties

# Keep iOS and Android project templates
!packages/mobile/ios/App/
!packages/mobile/android/app/

# Capacitor auto-generated
packages/mobile/ios/capacitor.config.json
packages/mobile/android/capacitor.config.json
packages/mobile/ios/App/App.xcworkspace/
packages/mobile/ios/App/Podfile.lock

# Lighthouse / Performance reports (may contain API keys)
lighthouse-report.*
*.lighthouse.*
lighthouse/
*.report.json
*.report.html

# Security - prevent accidental secret/key commits
*.pem
*.key
*.p12
*.pfx
*.keystore
*credentials*.json
*service-account*.json
