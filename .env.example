VITE_API_URL=http://localhost:3001
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (Get these from your new Dev Project)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (test mode keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Sentry (get DSNs from sentry.io — create React + Node.js projects)
VITE_SENTRY_DSN=
SENTRY_DSN=

# CORS — extra allowed origin (e.g. Vercel preview URL or staging domain)
CORS_ORIGIN=
