    "expects_response": true,
    "response_timeout_secs": 3,
    "parameters": [
        {
            "id": "name",
            "type": "string",
            "value_type": "llm_prompt",
            "description": "Name of the place or activity to add",
            "dynamic_variable": "",
            "constant_value": "",
            "enum": null,
            "is_system_provided": false,
            "required": true
        },
        {
            "id": "lat",
            "type": "number",
            "value_type": "llm_prompt",
