{
  "name": "nextdestination-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @nextdestination/web",
    "dev:web-next": "npm run dev -w @nextdestination/web-next",
    "build:web-next": "npm run build -w @nextdestination/web-next",
    "dev:mobile": "npm run dev -w @nextdestination/mobile",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently \"npm run dev:web-next\" \"npm run dev:server\"",
    "dev:all:legacy": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "build:web": "npm run build -w @nextdestination/web",
    "build:mobile": "npm run build -w @nextdestination/mobile",
    "build:shared": "npm run build -w @nextdestination/shared",
    "build:all": "npm run build:shared && npm run build:web && npm run build:mobile",
    "ios:open": "npm run cap:open -w @nextdestination/mobile",
    "ios:build": "npm run cap:build -w @nextdestination/mobile",
    "ios:run": "npm run cap:run -w @nextdestination/mobile"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "puppeteer-core": "^24.37.5",
    "typescript": "~5.8.2"
  }
}
